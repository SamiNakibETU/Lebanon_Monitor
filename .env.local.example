# Lebanon Monitor — Environment Variables
# Copy to .env.local and fill in values.

# NASA FIRMS (free): https://firms.modaps.eosdis.nasa.gov/api/map_key/
# FIRMS_MAP_KEY=

# OpenWeatherMap (free tier: 1000 calls/day)
# OWM_API_KEY=

# Cloudflare Radar (requires Cloudflare account)
# CF_API_TOKEN=

# OpenAQ v3 (free): https://explore.openaq.org/register
# OPENAQ_API_KEY=
