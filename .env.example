# Lebanon Monitor — Environment Variables
# Copy to .env.local (local) or configure in Railway Dashboard (deploy)
# See docs/DEPLOY.md for deployment instructions.

# Database (PostgreSQL, works without PostGIS)
# Required for persistence. Railway: reference ${{ Postgres.DATABASE_URL }}
# Local: postgresql://user:pass@localhost:5432/lebanon_monitor
# Windows: souvent postgresql://Proprietaire@localhost:5432/lebanon_monitor (voir docs/DEPLOY.md)
DATABASE_URL=

# NASA FIRMS (free: https://firms.modaps.eosdis.nasa.gov/api/map_key/)
FIRMS_MAP_KEY=

# OpenWeatherMap (free tier: https://openweathermap.org/api)
OWM_API_KEY=

# Cloudflare Radar (free account: https://dash.cloudflare.com/)
CF_API_TOKEN=

# Claude API — classification for ambiguous headlines (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Hugging Face Inference API (free: https://huggingface.co/settings/tokens)
# Enables enhanced NLP sentiment classification (keywords + HF + GDELT tone)
HF_API_TOKEN=

# OpenAQ v3 (https://explore.openaq.org/register)
OPENAQ_API_KEY=

# ACLED (free researcher account: https://acleddata.com/register/)
# ACLED_API_KEY=
# ACLED_EMAIL=

# UCDP API — request token from mertcan.yilmaz@pcr.uu.se. Limit: 5000 req/day.
# UCDP_ACCESS_TOKEN=

# ReliefWeb API (https://reliefweb.int/about/api)
# Appname approved via reliefweb.int — use your approved value
RELIEFWEB_APPNAME=

# Public app URL (for SEO, sitemap, Open Graph). Railway: https://your-app.railway.app
NEXT_PUBLIC_APP_URL=

# Telegram (RSS bridge). Comma-separated URLs from rss.app or similar for Telegram channels
# TELEGRAM_RSS_URLS=https://rss.app/feed/xxx,https://...
TELEGRAM_RSS_URLS=

# Ingest cron — secret for POST /api/admin/ingest (cron-job.org, etc.)
# Generate: openssl rand -hex 24
INGEST_SECRET=

# Upstash Redis (free: https://upstash.com/) — cache for synthesis, indicators
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
