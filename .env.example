# Lebanon Monitor — Environment Variables
# Copy to .env.local (local) or configure in Railway Dashboard (deploy)
# See docs/DEPLOY.md for deployment instructions.

# Database (PostgreSQL, works without PostGIS)
# Required for persistence. Railway: reference ${{ Postgres.DATABASE_URL }}
# Required for persistence. Local: postgresql://user:pass@localhost:5432/lebanon_monitor
DATABASE_URL=

# NASA FIRMS (free: https://firms.modaps.eosdis.nasa.gov/api/map_key/)
FIRMS_MAP_KEY=

# OpenWeatherMap (free tier: https://openweathermap.org/api)
OWM_API_KEY=

# Cloudflare Radar (free account: https://dash.cloudflare.com/)
CF_API_TOKEN=

# Hugging Face Inference API (free: https://huggingface.co/settings/tokens)
# Enables enhanced NLP sentiment classification (keywords + HF + GDELT tone)
HF_API_TOKEN=

# OpenAQ v3 (https://explore.openaq.org/register)
OPENAQ_API_KEY=

# UCDP API — request token from mertcan.yilmaz@pcr.uu.se
# Not wired to registry until DB stable. Limit: 5000 req/day.
# UCDP_ACCESS_TOKEN=

# ReliefWeb API (https://reliefweb.int/about/api)
# Appname approved via reliefweb.int — use your approved value
RELIEFWEB_APPNAME=

# ACLED (free researcher account: https://acleddata.com/register/)
# ACLED_API_KEY=
# ACLED_EMAIL=
