{
  "name": "lebanon-monitor",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:seed": "node scripts/run-seed.mjs",
    "db:check": "node -e \"const{Pool}=require('pg');const p=new Pool({connectionString:process.env.DATABASE_URL});p.query('SELECT 1').then(()=>{console.log('DB OK');process.exit(0)}).catch(e=>{console.error(e.message);process.exit(1)}).finally(()=>p.end())\"",
    "worker": "tsx src/worker/index.ts"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "d3": "^7.9.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "maplibre-gl": "^5.19.0",
    "next": "^16.1.6",
    "pg": "^8.13.0",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.7.0",
    "rss-parser": "^3.13.0",
    "swr": "^2.4.1",
    "youtubei.js": "^16.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
